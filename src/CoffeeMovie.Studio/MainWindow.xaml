<Window x:Class="CoffeeMovie.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CoffeeMovie Studio"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        Background="#05070B"
        Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="18,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="CoffeeMovie Studio" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="動画と字幕を取り込み、モバイル用のシーン情報を準備します" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="動画を追加" Click="OnImportVideoClicked" />
                    <Button Content="更新" Click="OnRefreshClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="動画棚" FontSize="16" FontWeight="SemiBold" Margin="14,12,14,8" />
                    <ListBox x:Name="MoviesListBox"
                             Grid.Row="1"
                             Background="#0B111A"
                             BorderThickness="0"
                             Foreground="White"
                             SelectionChanged="OnMovieSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="4" Background="#101824" BorderBrush="#1E2A3A" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding CacheState}" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="SummaryTextBlock" Grid.Row="2" Foreground="{StaticResource MutedBrush}" Margin="14,8,14,12" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="170" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="タイトル" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TitleTextBox" Margin="0,5,16,0" LostFocus="OnTitleLostFocus" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button x:Name="AddSubtitleButton" Content="字幕を追加" Click="OnImportSubtitleClicked" />
                            <Button x:Name="WriteSidecarButton" Content="サイドカーを書き出し" Click="OnWriteSidecarClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="FileNameTextBlock" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock x:Name="CachePathTextBlock" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                            <TextBlock x:Name="SizeTextBlock" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="PlayButton" Content="プレビュー再生" Click="OnPlayPreviewClicked" Background="#5DE0D0" />
                            <Button x:Name="StopButton" Content="停止" Click="OnStopPreviewClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Background="Black" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                        <MediaElement x:Name="PreviewPlayer" LoadedBehavior="Manual" UnloadedBehavior="Manual" Stretch="Uniform" />
                    </Border>

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="字幕" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="字幕シーン" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <DataGrid x:Name="SubtitlesDataGrid" Grid.Row="1" Grid.Column="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                                <DataGridTextColumn Header="形式" Binding="{Binding Format}" Width="80" />
                                <DataGridTextColumn Header="Cue" Binding="{Binding CueCount}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="ScenesDataGrid" Grid.Row="1" Grid.Column="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="90" />
                                <DataGridTextColumn Header="Text" Binding="{Binding Label}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusTextBlock" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>

