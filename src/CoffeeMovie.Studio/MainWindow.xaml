<Window x:Class="CoffeeMovie.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CoffeeMovie Studio"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        Background="#05070B"
        Foreground="White"
        AllowDrop="True"
        DragOver="OnWindowDragOver"
        Drop="OnWindowDrop"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="18,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="CoffeeMovie Studio" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="動画と字幕を取り込み、モバイル用のシーン情報を準備します" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Content="&#x30BF;&#x30B0;&#x7BA1;&#x7406;" Click="OnManageTagsClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                    <Button Content="Drive設定" Click="OnConfigureDriveSyncFolderClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                    <Button Content="CoffeeLearning設定" Click="OnConfigureCoffeeLearningClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                    <Button x:Name="ImportDrivePackagesButton" Content="Driveから取り込み" Click="OnImportDrivePackagesClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                    <Button Content="動画を追加" Click="OnImportVideoClicked" />
                    <Button Content="更新" Click="OnRefreshClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="動画棚" FontSize="16" FontWeight="SemiBold" Margin="14,12,14,8" />
                    <Grid Grid.Row="1" Margin="14,0,14,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="動画検索"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,3" />
                        <TextBox x:Name="MovieSearchTextBox"
                                 Grid.Row="1"
                                 Height="34"
                                 Padding="8,4"
                                 Margin="0,0,0,8"
                                 TextChanged="OnMovieFilterChanged"
                                 ToolTip="タイトル、作品名、Season、Episodeで検索" />
                        <TextBlock Grid.Row="2"
                                   Text="動画タグ絞り込み"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,3" />
                        <TextBox x:Name="MovieTagFilterTextBox"
                                 Grid.Row="3"
                                 Height="34"
                                 Padding="8,4"
                                 Margin="0,0,0,8"
                                 TextChanged="OnMovieFilterChanged"
                                 ToolTip="動画タグで絞り込み" />
                        <TextBlock Grid.Row="4"
                                   Text="字幕タグ絞り込み"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,3" />
                        <TextBox x:Name="SubtitleTagFilterTextBox"
                                 Grid.Row="5"
                                 Height="34"
                                 Padding="8,4"
                                 TextChanged="OnMovieFilterChanged"
                                 ToolTip="字幕タグを含む動画で絞り込み" />
                    </Grid>
                    <ListBox x:Name="MoviesListBox"
                             Grid.Row="2"
                             Background="#0B111A"
                             BorderThickness="0"
                             Foreground="White"
                             SelectionChanged="OnMovieSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="4" Background="#101824" BorderBrush="#1E2A3A" BorderThickness="1" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="86" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="78"
                                                Height="44"
                                                Background="#05070B"
                                                BorderBrush="#27364A"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                ClipToBounds="True"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top">
                                            <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding CacheState}" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="SummaryTextBlock" Grid.Row="3" Foreground="{StaticResource MutedBrush}" Margin="14,8,14,12" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <TabControl x:Name="MainTabControl" SelectionChanged="OnMainTabSelectionChanged">
                    <TabItem x:Name="EditTabItem" Header="編集">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="14" MinWidth="760">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="170" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="420" MinHeight="320" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="タイトル" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TitleTextBox" Margin="0,5,16,0" LostFocus="OnTitleLostFocus" />
                            <Grid Margin="0,8,16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="&#x4F5C;&#x54C1;&#x540D;" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="Season" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="2" Text="Episode" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="8,0,0,0" />
                                <TextBox x:Name="SeriesTitleTextBox" Grid.Row="1" Margin="0,4,0,0" LostFocus="OnMovieMetadataLostFocus" />
                                <TextBox x:Name="SeasonNumberTextBox" Grid.Row="1" Grid.Column="1" Margin="8,4,0,0" LostFocus="OnMovieMetadataLostFocus" TextAlignment="Right" />
                                <TextBox x:Name="EpisodeNumberTextBox" Grid.Row="1" Grid.Column="2" Margin="8,4,0,0" LostFocus="OnMovieMetadataLostFocus" TextAlignment="Right" />
                                <Button x:Name="MovieTagsButton"
                                        Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Content="&#x52D5;&#x753B;&#x30BF;&#x30B0;&#x3092;&#x9078;&#x629E;"
                                        Click="OnSelectMovieTagsClicked"
                                        Margin="0,8,0,0"
                                        MinWidth="160"
                                        HorizontalAlignment="Left"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button x:Name="AddSubtitleButton" Content="字幕を追加" Click="OnImportSubtitleClicked" />
                            <Button x:Name="WriteSidecarButton" Content="サイドカーを書き出し" Click="OnWriteSidecarClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                            <Button x:Name="ExportDrivePackageButton" Content="スマホ用書き出し" Click="OnExportDrivePackageClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="FileNameTextBlock" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock x:Name="CachePathTextBlock" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                            <TextBlock x:Name="SizeTextBlock" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="DualSubtitleButton"
                                    Content="両方表示: OFF"
                                    Click="OnToggleDualSubtitleClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <Button x:Name="LearningNotesButton"
                                    Content="メモ表示: OFF"
                                    Click="OnToggleLearningNotesClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <Button x:Name="CoffeeLearningRegisterButton"
                                    Content="単語登録"
                                    Click="OnRegisterCoffeeLearningClicked"
                                    Background="#5DE0D0"
                                    Foreground="#04100F"
                                    BorderBrush="#5DE0D0" />
                            <Button x:Name="PlayButton" Content="プレビュー再生" Click="OnPlayPreviewClicked" Background="#5DE0D0" />
                            <Button x:Name="PauseButton" Content="一時停止" Click="OnPausePreviewClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                            <Button x:Name="StopButton" Content="停止" Click="OnStopPreviewClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                            <Button x:Name="PreviewPopupButton" Content="別窓プレビュー" Click="OnOpenPreviewPopupClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                            <Button x:Name="CreateThumbnailButton" Content="サムネイル作成" Click="OnCreateThumbnailClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                            <Button x:Name="PlayThumbnailClipButton" Content="サムネ位置5秒" Click="OnPlayThumbnailClipClicked" Background="#121A26" Foreground="White" BorderBrush="#27364A" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Background="Black" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid ClipToBounds="True">
                            <MediaElement x:Name="PreviewPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          ScrubbingEnabled="True"
                                          Stretch="Uniform"
                                          MediaOpened="OnPreviewMediaOpened"
                                          MediaEnded="OnPreviewMediaEnded" />
                            <StackPanel x:Name="PreviewAboveOverlayPanel"
                                        Margin="36,14,36,0"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Stretch" />
                            <StackPanel x:Name="PreviewBelowOverlayPanel"
                                        Margin="36,0,36,14"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Stretch" />
                            <Border x:Name="PreviewLearningNoteOverlay"
                                    Visibility="Collapsed"
                                    Background="#C00B111A"
                                    BorderBrush="#5DE0D0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,7"
                                    Margin="36,14,36,0"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch">
                                <TextBlock x:Name="PreviewLearningNoteTextBlock"
                                           Foreground="#EAFBF8"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>
                            <Border x:Name="PreviewSubtitleOverlay"
                                    Visibility="Collapsed"
                                    Background="#B0000000"
                                    CornerRadius="6"
                                    Padding="12,7"
                                    Margin="36,0,36,14"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch"
                                    MouseLeftButtonUp="OnPreviewSubtitleClicked">
                                <StackPanel>
                                    <TextBlock x:Name="PreviewSubtitlePrimaryTextBlock"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="PreviewSubtitleSecondaryTextBlock"
                                               Visibility="Collapsed"
                                               Foreground="#E0E7F0"
                                               FontSize="15"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="PreviewSeekSlider"
                                Minimum="0"
                                Maximum="0"
                                Value="0"
                                IsEnabled="False"
                                IsMoveToPointEnabled="True"
                                VerticalAlignment="Center"
                                PreviewMouseLeftButtonDown="OnPreviewSeekStarted"
                                PreviewMouseLeftButtonUp="OnPreviewSeekCompleted"
                                KeyUp="OnPreviewSeekKeyUp"
                                ValueChanged="OnPreviewSeekValueChanged" />
                        <TextBlock x:Name="PreviewPositionTextBlock"
                                   Grid.Column="1"
                                   Text="00:00 / 00:00"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </Grid>

                    <WrapPanel Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center">
                        <TextBlock Text="表示位置"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBlock Text="英語"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <ComboBox x:Name="EnglishSubtitlePositionComboBox"
                                  Width="74"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="OnOverlayPositionChanged"
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="上1" Tag="above1" />
                            <ComboBoxItem Content="上2" Tag="above2" />
                            <ComboBoxItem Content="上3" Tag="above3" />
                            <ComboBoxItem Content="上4" Tag="above4" />
                            <ComboBoxItem Content="下1" Tag="below1" />
                            <ComboBoxItem Content="下2" Tag="below2" />
                            <ComboBoxItem Content="下3" Tag="below3" />
                            <ComboBoxItem Content="下4" Tag="below4" />
                        </ComboBox>
                        <TextBlock Text="日本語"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <ComboBox x:Name="JapaneseSubtitlePositionComboBox"
                                  Width="74"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="OnOverlayPositionChanged"
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="上1" Tag="above1" />
                            <ComboBoxItem Content="上2" Tag="above2" />
                            <ComboBoxItem Content="上3" Tag="above3" />
                            <ComboBoxItem Content="上4" Tag="above4" />
                            <ComboBoxItem Content="下1" Tag="below1" />
                            <ComboBoxItem Content="下2" Tag="below2" />
                            <ComboBoxItem Content="下3" Tag="below3" />
                            <ComboBoxItem Content="下4" Tag="below4" />
                        </ComboBox>
                        <TextBlock Text="メモ1(AI)"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <ComboBox x:Name="AiNotePositionComboBox"
                                  Width="74"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="OnOverlayPositionChanged"
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="上1" Tag="above1" />
                            <ComboBoxItem Content="上2" Tag="above2" />
                            <ComboBoxItem Content="上3" Tag="above3" />
                            <ComboBoxItem Content="上4" Tag="above4" />
                            <ComboBoxItem Content="下1" Tag="below1" />
                            <ComboBoxItem Content="下2" Tag="below2" />
                            <ComboBoxItem Content="下3" Tag="below3" />
                            <ComboBoxItem Content="下4" Tag="below4" />
                        </ComboBox>
                        <TextBlock Text="メモ2(自分)"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <ComboBox x:Name="UserNotePositionComboBox"
                                  Width="74"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="OnOverlayPositionChanged"
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="上1" Tag="above1" />
                            <ComboBoxItem Content="上2" Tag="above2" />
                            <ComboBoxItem Content="上3" Tag="above3" />
                            <ComboBoxItem Content="上4" Tag="above4" />
                            <ComboBoxItem Content="下1" Tag="below1" />
                            <ComboBoxItem Content="下2" Tag="below2" />
                            <ComboBoxItem Content="下3" Tag="below3" />
                            <ComboBoxItem Content="下4" Tag="below4" />
                        </ComboBox>
                        <Button x:Name="ResetOverlayLayoutButton"
                                Content="既定に戻す"
                                Click="OnResetOverlayLayoutClicked"
                                Background="#121A26"
                                Foreground="White"
                                BorderBrush="#27364A" />
                    </WrapPanel>

                    <Grid Grid.Row="5" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="字幕ファイル"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,8" />
                        <Grid Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="字幕シーン" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock x:Name="SceneResultsModeTextBlock"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="タグ色"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <ComboBox x:Name="HighlightColorComboBox"
                                      Grid.Column="2"
                                      Width="82"
                                      SelectedValuePath="Tag"
                                      SelectionChanged="OnHighlightColorChanged"
                                      Margin="0,0,12,0">
                                <ComboBoxItem Content="黄" Tag="#F6C945" />
                                <ComboBoxItem Content="青" Tag="#5DADEC" />
                                <ComboBoxItem Content="緑" Tag="#7BD88F" />
                                <ComboBoxItem Content="桃" Tag="#FF8FB3" />
                            </ComboBox>
                            <CheckBox x:Name="FlaggedOnlyCheckBox"
                                      Grid.Column="3"
                                      Content="flagタグのみ"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"
                                      Checked="OnFlaggedOnlyChanged"
                                      Unchecked="OnFlaggedOnlyChanged" />
                            <Button x:Name="SelectSelectedSceneTagsButton"
                                     Grid.Column="4"
                                     Content="選択行タグ"
                                     Click="OnSelectSelectedSceneTagsClicked"
                                     Background="#121A26"
                                     Foreground="White"
                                     BorderBrush="#27364A" />
                            <Button x:Name="ClearSelectedSceneTagsButton"
                                     Grid.Column="5"
                                     Content="行タグクリア"
                                     Click="OnClearSelectedSceneTagsClicked"
                                     Background="#121A26"
                                     Foreground="White"
                                     BorderBrush="#27364A" />
                            <Button x:Name="PlayFlaggedButton"
                                    Grid.Column="6"
                                    Content="次のflag再生"
                                    Click="OnPlayNextFlaggedCueClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <StackPanel Grid.Row="1"
                                        Grid.ColumnSpan="7"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,8,0,0">
                                <TextBlock Text="字幕タグ絞り込み"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="SceneTagFilterTextBox"
                                         Width="160"
                                         TextChanged="OnSceneFilterChanged"
                                         ToolTip="カンマ区切りで字幕タグを絞り込み" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,8">
                            <TextBlock Text="タイミング"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <Button Content="開始=現在"
                                    Click="OnSetSelectedCueStartFromPreviewClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <Button Content="終了=現在"
                                    Click="OnSetSelectedCueEndFromPreviewClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <Button Content="早める"
                                    Click="OnShiftSelectedCueEarlierClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <TextBox x:Name="TimingShiftTextBox"
                                     Width="58"
                                     Text="100"
                                     TextAlignment="Right"
                                     Margin="0,0,4,0" />
                            <TextBlock Text="ms"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <Button Content="遅らせる"
                                    Click="OnShiftSelectedCueLaterClicked"
                                    Background="#121A26"
                                    Foreground="White"
                                    BorderBrush="#27364A" />
                            <CheckBox x:Name="SyncPairedSubtitleCheckBox"
                                      Content="英日同期"
                                      IsChecked="True"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="4,0,12,0" />
                            <CheckBox x:Name="OriginalSubtitleWriteBackCheckBox"
                                      Content="原本にも反映"
                                      IsChecked="True"
                                      Foreground="White"
                                      VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Grid.RowSpan="2"
                              Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="SubtitlesDataGrid"
                                      Grid.Row="0"
                                      SelectionMode="Single"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      SelectionChanged="OnSubtitleSelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                                    <DataGridTextColumn Header="Lang" Binding="{Binding Language}" Width="55" />
                                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="110" />
                                    <DataGridTextColumn Header="形式" Binding="{Binding Format}" Width="80" />
                                    <DataGridTextColumn Header="Cue" Binding="{Binding CueCount}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,8,0,0">
                                <Button x:Name="RemoveSubtitleButton"
                                        Content="選択字幕を削除"
                                        Click="OnRemoveSubtitleClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                            </StackPanel>
                        </Grid>

                        <DataGrid x:Name="ScenesDataGrid"
                                  Grid.Row="2"
                                  Grid.Column="2"
                                  IsReadOnly="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  MouseDoubleClick="OnSceneMouseDoubleClick"
                                  CurrentCellChanged="OnSceneCurrentCellChanged"
                                  CellEditEnding="OnSceneCellEditEnding">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="{Binding RowBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#173447" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="SceneMovieColumn" Header="動画" Binding="{Binding SourceMovie}" Width="180" IsReadOnly="True" Visibility="Collapsed" />
                                <DataGridTextColumn x:Name="SceneTrackColumn" Header="字幕" Binding="{Binding SourceTrack}" Width="120" IsReadOnly="True" Visibility="Collapsed" />
                                <DataGridCheckBoxColumn Header="flag" Binding="{Binding IsFlagged, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                                <DataGridTextColumn Header="Start" Binding="{Binding Timestamp, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="92" />
                                <DataGridTextColumn Header="End" Binding="{Binding EndTimestamp, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="92" />
                                <DataGridTextColumn Header="Text" Binding="{Binding Label}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="Listen" Binding="{Binding ListeningAccuracy}" Width="70" IsReadOnly="True" />
                                <DataGridTextColumn Header="Shadow" Binding="{Binding ShadowingAccuracy}" Width="78" IsReadOnly="True" />
                                <DataGridTextColumn Header="Tags" Binding="{Binding Tags}" Width="130" IsReadOnly="True" />
                                <DataGridTextColumn Header="CL" Binding="{Binding CoffeeLearningStatus}" Width="42" IsReadOnly="True" />
                                <DataGridTemplateColumn Header="タグ選択" Width="76">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="選択"
                                                    Click="OnSelectSceneRowTagsClicked"
                                                    IsEnabled="{Binding CanEditTags}"
                                                    MinHeight="26"
                                                    MinWidth="54"
                                                    Padding="8,2"
                                                    Margin="0"
                                                    FontSize="12"
                                                    Background="#121A26"
                                                    Foreground="White"
                                                    BorderBrush="#27364A" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="AI&#x30E1;&#x30E2;" Binding="{Binding AiNote, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="220" />
                                <DataGridTextColumn Header="自分メモ" Binding="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="SubtitleGenerationTabItem" Header="字幕生成">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                        <Grid Margin="16" MinWidth="1280">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="対象動画" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock x:Name="GenerationMovieTextBlock"
                                           Text="動画を選択してください"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,8,0,0" />
                                <TextBlock x:Name="SubtitleGenerationStateTextBlock"
                                           Text="待機中"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Pythonコマンド" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="WhisperPythonCommandTextBox" Grid.Row="0" Grid.Column="1" Text="py" Margin="0,0,12,8" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="実行引数" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="WhisperPythonArgumentsTextBox" Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="3" Text="-3.10 -m whisperx" Margin="0,0,0,8" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="出力先" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="WhisperOutputDirectoryTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,8,8" />
                                <Button x:Name="BrowseWhisperOutputDirectoryButton"
                                        Grid.Row="1"
                                        Grid.Column="4"
                                        Content="参照"
                                        Click="OnBrowseWhisperOutputDirectoryClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <Button x:Name="SaveWhisperDefaultsButton"
                                        Grid.Row="1"
                                        Grid.Column="5"
                                        Content="既定に設定"
                                        Click="OnSaveWhisperDefaultsClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Model" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="WhisperModelTextBox" Grid.Row="2" Grid.Column="1" Text="medium" Margin="0,0,12,8" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Language" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="WhisperLanguageTextBox" Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="3" Text="en" Margin="0,0,0,8" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Device" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="WhisperDeviceComboBox" Grid.Row="3" Grid.Column="1" SelectedIndex="0" Margin="0,0,12,0">
                                    <ComboBoxItem Content="cuda" />
                                    <ComboBoxItem Content="cpu" />
                                </ComboBox>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Compute" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="WhisperComputeTypeComboBox" Grid.Row="3" Grid.Column="3" SelectedIndex="0" Margin="0,0,12,0">
                                    <ComboBoxItem Content="float16" />
                                    <ComboBoxItem Content="float32" />
                                    <ComboBoxItem Content="int8" />
                                </ComboBox>
                                <TextBlock Grid.Row="3"
                                           Grid.Column="4"
                                           Grid.ColumnSpan="2"
                                           Text="cuda=GPU / cpu=CPU。float16はGPU向け、float32は標準、int8は軽量。"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="5"
                                           Text="Pythonコマンドと実行引数はWhisperX環境を選ぶための詳細設定です。通常は py / -3.10 -m whisperx のままでOKです。"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="翻訳コマンド" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,16,8,8" />
                                <TextBox x:Name="TranslationCommandTextBox" Grid.Row="5" Grid.Column="1" Text="codex-spark" Margin="0,16,12,8" />
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="翻訳引数" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,16,8,8" />
                                <TextBox x:Name="TranslationArgumentsTextBox"
                                         Grid.Row="5"
                                         Grid.Column="3"
                                         Grid.ColumnSpan="3"
                                         Text="exec --full-auto -C &quot;{outputDir}&quot; --add-dir &quot;{inputDir}&quot; --skip-git-repo-check &quot;You are codex-spark for CoffeeMovie. Read the prompt file at {promptFile}, translate {input}, and write the Japanese SRT to {output}.&quot;"
                                         Margin="0,16,0,8" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Source" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="TranslationSourceLanguageTextBox" Grid.Row="6" Grid.Column="1" Text="en" Margin="0,0,12,0" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="Target" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="TranslationTargetLanguageTextBox" Grid.Row="6" Grid.Column="3" Text="ja" Margin="0,0,12,0" />
                                <TextBlock Grid.Row="6" Grid.Column="4" Text="AIモデル" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="TranslationModelTextBox"
                                         Grid.Row="6"
                                         Grid.Column="5"
                                         Width="210"
                                         Text="gpt-5.3-codex-spark"
                                         Margin="0" />
                                <TextBlock Grid.Row="7"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="5"
                                           Text="codex-sparkはStudio側の既定プリセットです。AIモデル欄はCodex CLIの -m に反映します。Gemini等はコマンド/引数を差し替え、必要なら {model} を引数テンプレートで使えます。"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="5"
                                           Text="プレースホルダ: {input}=英語SRT、{output}=日本語SRT、{notesOutput}=AIメモJSON、{inputDir}/{outputDir}=各フォルダ、{promptFile}=プロンプトファイル、{source}/{target}=言語、{model}=AIモデル、{audienceLevel}=AIメモ対象者レベル、{movie}=動画、{title}=タイトル。"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Text="AIメモ対象"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,14,8,0" />
                                <ComboBox x:Name="LearningNotesAudienceLevelComboBox"
                                          Grid.Row="9"
                                          Grid.Column="1"
                                          Width="110"
                                          SelectedIndex="2"
                                          Margin="0,14,12,0">
                                    <ComboBoxItem Content="A1" />
                                    <ComboBoxItem Content="A2" />
                                    <ComboBoxItem Content="B1" />
                                    <ComboBoxItem Content="B2" />
                                    <ComboBoxItem Content="C1" />
                                    <ComboBoxItem Content="C2" />
                                </ComboBox>
                                <TextBlock Grid.Row="9"
                                           Grid.Column="2"
                                           Grid.ColumnSpan="4"
                                           Text="対象者レベル未満の通常表現は出力せず、難語・世界観語・慣用句だけAIメモに残します。"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="0,14,0,0" />
                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Text="翻訳プロンプト"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Top"
                                           Margin="0,14,8,0" />
                                <TextBox x:Name="TranslationPromptTextBox"
                                         Grid.Row="10"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="4"
                                         Height="116"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,14,8,0" />
                                <Button x:Name="ResetTranslationPromptButton"
                                        Grid.Row="10"
                                        Grid.Column="5"
                                        Content="ベースに戻す"
                                        Click="OnResetTranslationPromptClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A"
                                        VerticalAlignment="Top"
                                        Margin="0,14,0,0" />
                                <TextBlock Grid.Row="11"
                                           Grid.Column="0"
                                           Text="AIメモプロンプト"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Top"
                                           Margin="0,14,8,0" />
                                <TextBox x:Name="LearningNotesPromptTextBox"
                                         Grid.Row="11"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="4"
                                         Height="116"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,14,8,0" />
                                <Button x:Name="ResetLearningNotesPromptButton"
                                        Grid.Row="11"
                                        Grid.Column="5"
                                        Content="ベースに戻す"
                                        Click="OnResetLearningNotesPromptClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A"
                                        VerticalAlignment="Top"
                                        Margin="0,14,0,0" />
                            </Grid>

                            <WrapPanel Grid.Row="2" Margin="0,16,0,12">
                                <Button x:Name="GenerateEnglishSubtitleButton"
                                        Content="英語字幕を生成"
                                        Click="OnGenerateEnglishSubtitleClicked" />
                                <Button x:Name="GenerateJapaneseSubtitleButton"
                                        Content="日本語訳を生成"
                                        Click="OnGenerateJapaneseSubtitleClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <Button x:Name="GenerateEnglishAndJapaneseSubtitleButton"
                                        Content="英日を生成"
                                        Click="OnGenerateEnglishAndJapaneseSubtitleClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <Button x:Name="GenerateAiNotesButton"
                                        Content="AIメモ追加"
                                        Click="OnGenerateAiNotesClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <TextBlock Text="英語生成"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,4,0" />
                                <ComboBox x:Name="EnglishSubtitleGenerationModeComboBox"
                                          Width="210"
                                          SelectedValuePath="Tag"
                                          SelectedIndex="0"
                                          Margin="0,0,8,0">
                                    <ComboBoxItem Content="通常" Tag="normal" />
                                    <ComboBoxItem Content="&#x5B9F;&#x9A13;: 3&#x56DE;&#x6BD4;&#x8F03;/&#x6B20;&#x640D;&#x88DC;&#x6B63;" Tag="review" />
                                </ComboBox>
                                <CheckBox x:Name="OverwriteGeneratedSubtitleCheckBox"
                                          Content="既存.en.srtを退避して再生成"
                                          Foreground="White"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0" />
                                <CheckBox x:Name="OverwriteJapaneseSubtitleCheckBox"
                                          Content="既存.ja.srtを退避して再生成"
                                          Foreground="White"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0" />
                            </WrapPanel>

                            <TextBox x:Name="SubtitleGenerationLogTextBox"
                                     Grid.Row="3"
                                     MinHeight="180"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12" />
                        </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="FullPreviewTabItem" Header="フルプレビュー">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="Black" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                <Grid ClipToBounds="True">
                                    <MediaElement x:Name="FullPreviewPlayer"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Manual"
                                                  ScrubbingEnabled="True"
                                                  Stretch="Uniform"
                                                  MediaOpened="OnFullPreviewMediaOpened"
                                                  MediaEnded="OnFullPreviewMediaEnded" />
                                    <StackPanel x:Name="FullPreviewAboveOverlayPanel"
                                                Margin="56,24,56,0"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Stretch" />
                                    <StackPanel x:Name="FullPreviewBelowOverlayPanel"
                                                Margin="56,0,56,28"
                                                VerticalAlignment="Bottom"
                                                HorizontalAlignment="Stretch" />
                                    <Border x:Name="FullPreviewLearningNoteOverlay"
                                            Visibility="Collapsed"
                                            Background="#C00B111A"
                                            BorderBrush="#5DE0D0"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="18,10"
                                            Margin="56,24,56,0"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Stretch">
                                        <TextBlock x:Name="FullPreviewLearningNoteTextBlock"
                                                   Foreground="#EAFBF8"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                    <Border x:Name="FullPreviewSubtitleOverlay"
                                            Visibility="Collapsed"
                                            Background="#B0000000"
                                            CornerRadius="6"
                                            Padding="18,10"
                                            Margin="56,0,56,28"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock x:Name="FullPreviewSubtitlePrimaryTextBlock"
                                                       Foreground="White"
                                                       FontSize="26"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <TextBlock x:Name="FullPreviewSubtitleSecondaryTextBlock"
                                                       Visibility="Collapsed"
                                                       Foreground="#E0E7F0"
                                                       FontSize="20"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="108" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="FullPreviewPlayButton"
                                        Grid.Column="0"
                                        Content="再生"
                                        Click="OnFullPreviewPlayClicked" />
                                <Button x:Name="FullPreviewPauseButton"
                                        Grid.Column="1"
                                        Content="一時停止"
                                        Click="OnPauseFullPreviewClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <Button x:Name="FullPreviewStopButton"
                                        Grid.Column="2"
                                        Content="停止"
                                        Click="OnFullPreviewStopClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <Button x:Name="FullPreviewLearningNotesButton"
                                        Grid.Column="3"
                                        Content="メモ表示: OFF"
                                        Click="OnToggleLearningNotesClicked"
                                        Background="#121A26"
                                        Foreground="White"
                                        BorderBrush="#27364A" />
                                <Button x:Name="FullPreviewCoffeeLearningRegisterButton"
                                        Grid.Column="4"
                                        Content="単語登録"
                                        Click="OnRegisterCoffeeLearningClicked"
                                        Background="#5DE0D0"
                                        Foreground="#04100F"
                                        BorderBrush="#5DE0D0" />
                                <Slider x:Name="FullPreviewSeekSlider"
                                        Grid.Column="5"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="0"
                                        IsEnabled="False"
                                        IsMoveToPointEnabled="True"
                                        VerticalAlignment="Center"
                                        PreviewMouseLeftButtonDown="OnFullPreviewSeekStarted"
                                        PreviewMouseLeftButtonUp="OnFullPreviewSeekCompleted"
                                        KeyUp="OnFullPreviewSeekKeyUp"
                                        ValueChanged="OnFullPreviewSeekValueChanged" />
                                <TextBlock x:Name="FullPreviewPositionTextBlock"
                                           Grid.Column="6"
                                           Text="00:00 / 00:00"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="54" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <ProgressBar x:Name="StatusProgressBar"
                             Grid.Column="1"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"
                             Margin="16,0,8,0" />
                <TextBlock x:Name="StatusProgressTextBlock"
                           Grid.Column="2"
                           Text="0%"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>
    </Grid>
</Window>

