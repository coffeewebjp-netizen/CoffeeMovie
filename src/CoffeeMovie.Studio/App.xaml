<Application x:Class="CoffeeMovie.Studio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0B111A" />
        <SolidColorBrush x:Key="BorderBrush" Color="#1E2A3A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5DE0D0" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A5B3C6" />
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="#04100F" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#101824" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#27364A" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B111A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1E2A3A" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#1E2A3A" />
            <Setter Property="RowBackground" Value="#0B111A" />
            <Setter Property="AlternatingRowBackground" Value="#101824" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Application.Resources>
</Application>

